@page "/studenti"
@using TodoList.Models

<h3 class="text-center mt-3">Lista Studenti</h3>

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3 gap-2">
        <div class="input-group w-50">
            <span class="input-group-text">🔍</span>
            <input class="form-control" placeholder="Cerca per nome, cognome o email" @bind="searchTerm" />
        </div>

        <div class="d-flex gap-2">
            <a class="btn btn-success" href="/studenti/add">
                <i class="bi bi-plus-lg"></i> Aggiungi Studente
            </a>
            <span class="badge bg-secondary align-self-center">Totale: @filteredStudenti.Count()</span>
        </div>
    </div>

    <div class="table-responsive shadow-sm border rounded">
        <table class="table table-hover table-striped mb-0">
            <thead class="table-dark">
                <tr>
                    <th scope="col">#</th>
                    <th scope="col">Nome</th>
                    <th scope="col">Cognome</th>
                    <th scope="col">Email</th>
                    <th scope="col">Data di Nascita</th>
                    <th scope="col" class="text-end">Azioni</th>
                </tr>
            </thead>
            <tbody>
                @if (!filteredStudenti.Any())
                {
                    <tr>
                        <td colspan="6" class="text-center py-4">Nessuno studente trovato.</td>
                    </tr>
                }
                else
                {
                    @foreach (var studente in filteredStudenti)
                    {
                        <tr>
                            <th scope="row">@studente.StudenteId</th>
                            <td>@studente.Nome</td>
                            <td>@studente.Cognome</td>
                            <td>@studente.Email</td>
                            <td>@studente.DataNascita.ToString("dd/MM/yyyy")</td>
                            <td class="text-end">
                                <a class="btn btn-outline-primary btn-sm me-2" href="@($"/studenti/edit/{studente.StudenteId}")">Modifica</a>
                                <button class="btn btn-outline-danger btn-sm" @onclick="() => PromptDelete(studente.StudenteId, studente.Nome, studente.Cognome)">
                                    Cancella
                                </button>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>

@* Modal di conferma cancellazione (semplice, senza JS esterno) *@
@if (showDeleteModal && studentToDelete is not null)
{
    <div class="modal-backdrop fade show"></div>
    <div class="modal d-block" tabindex="-1" style="background: rgba(0,0,0,0.3);">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Conferma cancellazione</h5>
                    <button type="button" class="btn-close" @onclick="CancelDelete" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <p>Sei sicuro di voler cancellare <strong>@studentToDelete.Nome @studentToDelete.Cognome</strong>?</p>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="CancelDelete">Annulla</button>
                    <button class="btn btn-danger" @onclick="ConfirmDelete">Conferma cancellazione</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<Studenti> studenti = new();
    private string searchTerm = string.Empty;
    private bool showDeleteModal = false;
    private Studenti? studentToDelete;

    protected override void OnInitialized()
    {
        studenti = LoadData();
    }

    private IEnumerable<Studenti> filteredStudenti =>
        string.IsNullOrWhiteSpace(searchTerm)
            ? studenti
            : studenti.Where(s =>
                s.Nome.Contains(searchTerm, StringComparison.OrdinalIgnoreCase)
                || s.Cognome.Contains(searchTerm, StringComparison.OrdinalIgnoreCase)
                || s.Email.Contains(searchTerm, StringComparison.OrdinalIgnoreCase));

    private List<Studenti> LoadData()
    {
        return new List<Studenti>
        {
            new Studenti {StudenteId = 1, Nome = "Daniele", Cognome = "Nori", Email = "email@email.it", DataNascita = new DateOnly(1999, 1, 2)},
            new Studenti {StudenteId = 2, Nome = "Rafael", Cognome= "Abreu Fonseca", Email="rafael.abreu.fonseca@gmail.com", DataNascita=new DateOnly(1991,12,31)},
            new Studenti {StudenteId = 3, Nome = "Giulia", Cognome = "Bellotto", Email="g.bellotto@gmail.com", DataNascita = new DateOnly(1988,4,1)},
            new Studenti {StudenteId = 4, Nome = "Giorgio", Cognome = "Befani", Email = "giorgiobefani.97@gmail.com", DataNascita = new DateOnly(1997,3,17)},
            new Studenti {StudenteId = 5, Nome = "Cristian", Cognome = "Arcidiacono", Email = "cri.arcidiacono@libero.it", DataNascita = new DateOnly(1998,1,8)},
            new Studenti {StudenteId = 6, Nome = "Ilaria", Cognome = "Di Pretoro", Email = "iladipre@hotmail.com", DataNascita = new DateOnly(1992,2,17)},
            new Studenti {StudenteId = 7, Nome = "Yevgeniy", Cognome = "Di Pretoro", Email = "eugeniosakharov0@gmail.com", DataNascita = new DateOnly(2004,2,26)},
            new Studenti {StudenteId = 8, Nome = "Nadia Ester", Cognome = "Wolkowa Zinkiewicz", Email = "ester.zinkiewicz@gmail.com", DataNascita = new DateOnly(1987,11,1)},
            new Studenti {StudenteId = 9, Nome = "Alessio", Cognome = "Attilia", Email = "a.attilia@gmail.com", DataNascita = new DateOnly(2003,7,3)},
            new Studenti {StudenteId= 10, Nome = "Luca", Cognome = "Schiavone", Email = "lucaschiavone@gov.it", DataNascita = new DateOnly(1980,2,11)}
        };
    }

    private void PromptDelete(int id, string nome, string cognome)
    {
        studentToDelete = studenti.FirstOrDefault(s => s.StudenteId == id);
        showDeleteModal = studentToDelete is not null;
    }

    private void CancelDelete()
    {
        studentToDelete = null;
        showDeleteModal = false;
    }

    private void ConfirmDelete()
    {
        if (studentToDelete is not null)
        {
            studenti.Remove(studentToDelete);
        }
        CancelDelete();
    }
}
